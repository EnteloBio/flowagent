# Security
SECRET_KEY=your-secret-key-here  # Required: Generate a secure random key

# Environment
ENVIRONMENT=development
DEBUG=false

# ── LLM Provider ──────────────────────────────────────────────
# Choose your provider: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1             # or anthropic/claude-sonnet-4-20250514, gemini-2.5-flash, ollama/llama4
LLM_FALLBACK_MODEL=gpt-4.1-mini
# LLM_BASE_URL=                # set for Ollama (http://localhost:11434/v1) or custom endpoints

# Provider API keys (set the one matching your LLM_PROVIDER)
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# Legacy OpenAI settings (still work for backwards compatibility)
# OPENAI_MODEL=gpt-4.1
# OPENAI_FALLBACK_MODEL=gpt-4.1-mini

# ── Rate Limiting ─────────────────────────────────────────────
MAX_RETRIES=5
RETRY_DELAY=2.0
REQUEST_INTERVAL=1.0

# ── Agent Settings ────────────────────────────────────────────
MAX_CONCURRENT_WORKFLOWS=5
WORKFLOW_TIMEOUT=3600
AGENT_TIMEOUT=30.0
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY=1.0

# ── Pipeline Generation ──────────────────────────────────────
PIPELINE_FORMAT=shell          # shell | nextflow | snakemake
# PIPELINE_PROFILE=local       # Nextflow profile (local, docker, singularity, slurm)
# CONTAINER_ENGINE=docker      # docker | singularity | conda
# AUTO_EXECUTE_PIPELINE=true

# ── Executor Settings ────────────────────────────────────────
EXECUTOR_TYPE=local            # local | cgat | hpc | kubernetes | nextflow | snakemake
HPC_SYSTEM=slurm              # slurm | sge | torque
HPC_QUEUE=all.q
HPC_DEFAULT_MEMORY=4G
HPC_DEFAULT_CPUS=1
HPC_DEFAULT_TIME=60

# ── Kubernetes ────────────────────────────────────────────────
# KUBERNETES_ENABLED=false
# KUBERNETES_NAMESPACE=default
# KUBERNETES_IMAGE=python:3.11

# ── Monitoring ────────────────────────────────────────────────
ENABLE_MONITORING=true
METRICS_PORT=9090
LOG_LEVEL=INFO
