# ── LLM Provider ─────────────────────────────────────────────
# Choose your provider: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini               # or claude-sonnet-4-20250514, gemini-2.5-flash, llama4
LLM_FALLBACK_MODEL=gpt-4.1-mini
# LLM_BASE_URL=                       # set for Ollama (http://localhost:11434/v1) or custom endpoints

# Provider API keys (set the one matching your LLM_PROVIDER)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# ── Rate Limiting ────────────────────────────────────────────
MAX_RETRIES=5
RETRY_DELAY=2.0
TIMEOUT=60.0

# ── Workflow ─────────────────────────────────────────────────
MAX_CONCURRENT_WORKFLOWS=5
WORKFLOW_TIMEOUT=3600

# ── Pipeline Generation ─────────────────────────────────────
PIPELINE_FORMAT=shell                 # shell | nextflow | snakemake
# PIPELINE_PROFILE=local              # Nextflow profile (local, docker, singularity, slurm)

# ── Executor Settings ───────────────────────────────────────
EXECUTOR_TYPE=local                   # local | cgat | hpc | kubernetes | nextflow | snakemake
HPC_SYSTEM=slurm                     # slurm | sge | torque
HPC_QUEUE=all.q
HPC_DEFAULT_MEMORY=4G
HPC_DEFAULT_CPUS=1
HPC_DEFAULT_TIME=60

# ── Kubernetes ───────────────────────────────────────────────
# KUBERNETES_ENABLED=false
# KUBERNETES_NAMESPACE=default
# KUBERNETES_SERVICE_ACCOUNT=default
# KUBERNETES_IMAGE=python:3.11
# KUBERNETES_CPU_REQUEST=0.5
# KUBERNETES_CPU_LIMIT=1.0
# KUBERNETES_MEMORY_REQUEST=512Mi
# KUBERNETES_MEMORY_LIMIT=1Gi
# KUBERNETES_JOB_TTL=3600

# ── Monitoring ───────────────────────────────────────────────
ENABLE_MONITORING=true
METRICS_PORT=9090
LOG_LEVEL=INFO
